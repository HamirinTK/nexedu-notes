---
import { getCollection } from 'astro:content';

interface Course {
  name: string;
  url: string;
}

interface Props {
  heading: string;
  courses: Course[];
  domain: string;
  tagline: string;
  subtext: string;
  creditsHeading: string;
  creditsHeading2: string;
  creditsHeading3: string;
  lang?: string;
  noTopicsMessage?: string;
}

const {
  heading,
  courses,
  domain,
  tagline,
  subtext,
  creditsHeading,
  creditsHeading2,
  creditsHeading3,
  lang = 'en',
  noTopicsMessage,
} = Astro.props;

// ── Constants ──
const link2Text = "N-N-N";
const link2Url = "https://n-n-n-website.onrender.com/";
const link3Text = "GitHub";
const link3Url = "https://github.com/HamirinTK/nexedu-notes";

// ── Build a map: subject ID → array of topics (name, url) ──
// 1. Generate subject ID from the provided course URL
const coursesWithId = courses.map((course) => {
  // Remove leading/trailing slashes → e.g., "/math/" → "math"
  const id = course.url.replace(/^\/|\/$/g, '');
  return { ...course, id };
});

// 2. Fetch all docs once
const allDocs = await getCollection('docsMeta');

// 3. Initialize the map with empty arrays
const courseTopicsMap: Record<string, { name: string; url: string }[]> = {};
coursesWithId.forEach((course) => {
  courseTopicsMap[course.id] = [];
});

// 4. Populate topics from real MDX files
allDocs.forEach((doc) => {
  const normalizedId = doc.id.replace(/^src\/content\/docs\//, '');
  const parts = normalizedId.split('/'); 
  
  if (parts[0] === lang && parts.length >= 3) {
    const subject = parts[1];             // "math"
    if (courseTopicsMap[subject] !== undefined) {
      let cleanPath = normalizedId.replace(/\.[^/.]+$/, ''); // strip extension
      const pathParts = cleanPath.split('/');
      // Case A: File name matches folder name (e.g., test/test -> test)
      if (pathParts.length >= 2 && pathParts[pathParts.length - 1] === pathParts[pathParts.length - 2]) {
        pathParts.pop();
        cleanPath = pathParts.join('/');
      }
      // Case B: File is an index inside a subfolder (e.g., test/index -> test)
      else if (pathParts.length >= 2 && pathParts[pathParts.length - 1] === 'index') {
        pathParts.pop();
        cleanPath = pathParts.join('/');
      }
      const cleanUrl = `/${cleanPath}`;
      // Prevent mapping the main course index overview (e.g., en/math/index) as a subtopic
      if (pathParts.length >= 3) {
        courseTopicsMap[subject].push({
          name: doc.data.title || 'Untitled Topic',
          url: cleanUrl,
        });
      }
    }
  }
});
---

<div class="homepage-split-container">
  
  <!-- LEFT HALF: Subject List -->
  <div class="left-half">
    <p class="select-heading">{heading}</p>
    <div class="discipline-scroll-box">
      {coursesWithId.map((course) => (
        <a 
          href="#" 
          class="discipline-link" 
          data-subject-id={course.id}
          data-subject-name={course.name}
        >
          {course.name}
        </a>
      ))}
    </div>
    <hr class="course-list-end-line" />
  </div>

  <!-- RIGHT HALF: Dynamic Panel -->
  <div class="right-half brand-card">
    
    <!-- VIEW 1: Default Brand Info -->
    <div id="default-brand-view" class="view-panel active-view">
      <div class="brand-main-info">
        <p class="brand-domain">{domain}</p>
        <p class="brand-tagline">{tagline}</p>
        <p class="brand-subtext">{subtext}</p>
      </div>
      <div class="brand-credits">
        <p class="credits-heading">{creditsHeading}</p>
        <div class="credits-links">
          <a href="https://github.com/HamirinTK" target="_blank">HamirinTK</a>
          <span class="credit-separator">&</span>
          <a href="https://github.com/Mar13554" target="_blank">Mar13554</a>
        </div>
        <p class="credits-heading">{creditsHeading2}</p>
        <div class="credits-links">
          <a href={link2Url} target="_blank">{link2Text}</a>
        </div>
        <p class="credits-heading">{creditsHeading3}</p>
        <div class="credits-links">
          <a href={link3Url} target="_blank">{link3Text}</a>
        </div>
      </div>
    </div>

    <!-- VIEW 2: Topic Selector -->
    <div id="topic-selector-view" class="view-panel hidden-view">
      <div class="topic-header-row">
        <button id="back-to-brand-btn" class="circle-return-btn" aria-label="Return to brand info">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <h3 id="selected-subject-title" class="brand-domain">Subject Name</h3>
      </div>
      <div id="dynamic-topic-list" class="topic-list-container">
        <!-- Populated by JavaScript -->
      </div>
    </div>

  </div>
</div>

<script define:vars={{ courseTopicsMap, noTopicsMessage }}>
  // ── Debug: check map in console ──
  console.log('🗺️ courseTopicsMap loaded:', courseTopicsMap);

  const links = document.querySelectorAll('.discipline-link');
  const defaultView = document.getElementById('default-brand-view');
  const topicView = document.getElementById('topic-selector-view');
  const backBtn = document.getElementById('back-to-brand-btn');
  const topicList = document.getElementById('dynamic-topic-list');
  const subjectTitle = document.getElementById('selected-subject-title');

  links.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();

      const subjectId = link.dataset.subjectId;
      const subjectName = link.dataset.subjectName;
      const topics = courseTopicsMap[subjectId] || [];

      console.log(`📂 ${subjectName} → ${topics.length} topics found`);

      subjectTitle.textContent = subjectName;
      topicList.innerHTML = '';

      if (topics.length > 0) {
        topics.forEach(topic => {
          const a = document.createElement('a');
          a.href = topic.url;
          a.className = 'topic-sub-link';
          a.textContent = topic.name;
          topicList.appendChild(a);
        });
      } else {
        const msg = document.createElement('p');
        msg.className = 'no-topics-msg';
        msg.textContent = noTopicsMessage;
        topicList.appendChild(msg);
      }

      // Swap views
      defaultView.classList.remove('active-view');
      defaultView.classList.add('hidden-view');
      topicView.classList.remove('hidden-view');
      topicView.classList.add('active-view');
    });
  });

  backBtn.addEventListener('click', () => {
    topicView.classList.remove('active-view');
    topicView.classList.add('hidden-view');
    defaultView.classList.remove('hidden-view');
    defaultView.classList.add('active-view');
  });
</script>

<style>
  .course-list-end-line {
    margin: 24px 0 0 0;
    border: 0;
    border-top: 2px solid var(--sl-color-gray-5);
    opacity: 0.6;
  }
</style>