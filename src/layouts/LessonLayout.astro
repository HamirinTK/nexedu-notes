---
// src/layouts/LessonLayout.astro
import CustomHeader from '../components/CustomHeader.astro';
import LessonSidebar from '../components/LessonSidebar.astro';
import { Icon } from '@astrojs/starlight/components';
import '../styles/lesson.css';
import 'katex/dist/katex.min.css';

export interface Props {
  title?: string;
  description?: string;
  sidebarTitle?: string;
  image?: string;
  learnItems?: string[];
  learnLabel?: string;
  learnFallback?: string;
  dropdownLabel?: string;
  treeLabel?: string;
  showPractice?: boolean;
  practiceLabel?: string;
  showReturn?: boolean;
  returnLabel?: string;
  lang?: string;
  frontmatter?: Record<string, any>;
  entry?: { data: Record<string, any> };
}

// Safely merge Starlight's validated data with raw MDX frontmatter
const starlightData = Astro.props.entry?.data || {};
const mdxFrontmatter = Astro.props.frontmatter || {};
const props = { ...Astro.props, ...mdxFrontmatter, ...starlightData };

const {
  title = "Untitled",
  sidebarTitle,
  image,
  learnItems = [],
  learnLabel = "You will learn",
  learnFallback = "Details about this lesson will be updated soon.",
  dropdownLabel,
  treeLabel = "Topics",
  showPractice = true,
  practiceLabel = "Practice",
  showReturn = true,
  returnLabel = "Return",
} = props;

const sidebarTitleFinal = sidebarTitle || title;

// ── ROBUST ROUTING CHECK ──
// Segment-count based, so it doesn't depend on a `lang` prop matching the
// actual locale segment in the URL.
const pathname = Astro.url.pathname;
const pathSegments = pathname.split('/').filter(Boolean);

// Root homepage ("/") has 0 segments (or just "index")
const isWelcome = pathSegments.length === 0 || (pathSegments.length === 1 && pathSegments[0] === 'index');

// Course selector pages ("/en", "/th", "/en/index") have exactly 1 segment
const isSelector = pathSegments.length === 1 || (pathSegments.length === 2 && pathSegments[1] === 'index');
const isPractice = pathSegments[pathSegments.length - 1] === 'practice';
const cleanPath = pathSegments.join('/');
---

{isWelcome ? (
  <div class="welcome-ui-wrapper"><slot /></div>
) : isSelector ? (
  <div class="course-selector-ui-wrapper">
    <CustomHeader />
    <main class="course-selector-main-content"><slot /></main>
  </div>
) : isPractice ? (
  <slot />
) : (
  <div class="lesson-ui-wrapper">
    <CustomHeader />
    <div class="lesson-container">

      {/* Desktop sidebar — hidden on mobile via CSS, replaced by the
          bottom sheet below */}
      <LessonSidebar
        path={cleanPath}
        title={sidebarTitleFinal}
        image={image}
        learnItems={learnItems}
        learnLabel={learnLabel}
        learnFallback={learnFallback}
        dropdownLabel={dropdownLabel}
        treeLabel={treeLabel}
      />

      <div class="lesson-content">
        <div class="lesson-content-body"><slot /></div>

        <div class="lesson-actions-overlay">
          {showPractice && (
            <button class="btn-practice" id="practice-btn">
              <Icon name="open-book" size="1.2rem" /> {practiceLabel}
            </button>
          )}
          {showReturn && (
            <button class="btn-return-selector" id="return-selector-btn" title={returnLabel} aria-label={returnLabel}>
              <Icon name="left-arrow" size="1.4rem" />
            </button>
          )}
          <button class="btn-sidebar-toggle" id="mobile-sidebar-toggle" aria-label="Open Topics Menu">
            <Icon name="bars" size="1.4rem" />
          </button>
        </div>
      </div>

    </div>

    {/* Mobile-only sidebar replacement — same LessonSidebar content,
        rendered into a swipeable bottom sheet. Hidden on desktop via CSS. */}
    <div class="bottom-sheet-backdrop" id="lesson-sheet-backdrop"></div>
    <div class="bottom-sheet" id="lesson-bottom-sheet">
      <div class="bottom-sheet-handle"></div>
      <div class="bottom-sheet-content">
        <LessonSidebar
          path={cleanPath}
          title={sidebarTitleFinal}
          image={image}
          learnItems={learnItems}
          learnLabel={learnLabel}
          learnFallback={learnFallback}
          dropdownLabel={dropdownLabel}
          treeLabel={treeLabel}
        />
      </div>
    </div>
  </div>
)}

<script>
  function setupLessonUI() {
    document.body.style.overflow = '';

    document.getElementById('practice-btn')?.addEventListener('click', () => {
      const path = window.location.pathname.replace(/\/+$/, '');
      window.location.href = `${path}/practice`;
    });    
    document.getElementById('return-selector-btn')?.addEventListener('click', () => {
      const path = window.location.pathname.split('/').filter(Boolean)[0] || '';
      window.location.href = `/${path}/`;
    });

    // Mobile Bottom Sheet Configurations
    const toggleBtn = document.getElementById('mobile-sidebar-toggle');
    const sheet = document.getElementById('lesson-bottom-sheet');
    const backdrop = document.getElementById('lesson-sheet-backdrop');
    
    // Explicitly typed as HTMLElement to unlock native touch gestures in strict modules
    const handle = sheet?.querySelector<HTMLElement>('.bottom-sheet-handle');

    if (!sheet || !backdrop || !toggleBtn) return;

    const openSheet = () => {
      sheet.classList.add('active');
      backdrop.classList.add('active');
      document.body.style.overflow = 'hidden';
    };

    const closeSheet = () => {
      sheet.classList.remove('active');
      backdrop.classList.remove('active');
      sheet.style.transform = '';
      document.body.style.overflow = '';
    };

    toggleBtn.addEventListener('click', openSheet);
    backdrop.addEventListener('click', closeSheet);

    // Hardware touch drag mechanics
    let startY = 0;
    let currentY = 0;

    handle?.addEventListener('touchstart', (e: TouchEvent) => {
      startY = e.touches[0].clientY;
      sheet.style.transition = 'none';
    }, { passive: true });

    handle?.addEventListener('touchmove', (e: TouchEvent) => {
      currentY = e.touches[0].clientY;
      const deltaY = currentY - startY;
      if (deltaY > 0) {
        sheet.style.transform = `translateY(${deltaY}px)`;
      }
    }, { passive: true });

    handle?.addEventListener('touchend', () => {
      sheet.style.transition = 'transform 0.3s cubic-bezier(0.25, 1, 0.5, 1)';
      const deltaY = currentY - startY;
      if (deltaY > 120) {
        closeSheet();
      } else {
        sheet.style.transform = 'translateY(0)';
      }
      startY = 0;
      currentY = 0;
    });
  }

  setupLessonUI();
  document.addEventListener('astro:page-load', setupLessonUI);
</script>